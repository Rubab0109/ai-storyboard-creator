# Backend URL example: http://localhost:8000
APP_NAME=AI Storyboard Creator

# Frontend URL for CORS. For local testing use http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Optional LLM keys. The app works without keys using safe fallback prompts.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional image generation.
# If OPENAI_API_KEY is missing, the app returns a generated placeholder SVG image.
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional AI video generation via Replicate.
# Keep empty for fallback animated video preview in frontend.
REPLICATE_API_TOKEN=
REPLICATE_VIDEO_MODEL=

# Optional ElevenLabs TTS. If missing, frontend browser speech fallback is used.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Local storage folder. On Vercel, /tmp is used automatically.
STORAGE_DIR=
